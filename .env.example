APP_ENV=development
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=safeguard_ai
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
HF_MODEL_NAME=microsoft/deberta-v3-base
HF_CACHE_DIR=~/.cache/huggingface
HF_DEVICE=cpu
HF_ENABLE_MODEL=false
HF_USE_QUANTIZATION=true
HF_ALLOW_DOWNLOAD=false
HF_MAX_SEQUENCE_LENGTH=512
HF_BATCH_SIZE=32
EXPLAINABILITY_USE_MODEL=false
HF_ENABLE_GATE_MODEL=false
TOXIC_GATE_MODEL_NAME=microsoft/mdeberta-v3-base
TOXIC_GATE_THRESHOLD=0.35
HF_ENABLE_MULTILABEL_MODEL=false
TOXIC_MULTILABEL_MODEL_NAME=xlm-roberta-large
CONTEXT_LLM_ENABLED=false
CONTEXT_LLM_ENDPOINT=http://localhost:8001/v1/chat/completions
CONTEXT_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
CONTEXT_LLM_TIMEOUT_MS=4000
CONTEXT_ESCALATION_MIN_SCORE=0.55
CONTEXT_SERVICE_MODE=auto
UPSTREAM_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
UPSTREAM_API_KEY=your_openai_api_key
UPSTREAM_API_KEY_HEADER=Authorization
UPSTREAM_API_KEY_PREFIX=Bearer
UPSTREAM_TIMEOUT_MS=6000
GROOMING_MODEL=models/grooming_classifier
MAX_UPLOAD_BYTES=10485760
OCR_MAX_DIM=1800
OCR_UPSCALE_MIN_DIM=900
OCR_UPSCALE_FACTOR=1.5
OCR_ENABLE_EASYOCR_FALLBACK=true
OCR_FALLBACK_TIME_BUDGET_SEC=8.0
FIR_OUTPUT_DIR=/tmp/fir_pdfs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT_MS=180000
