# ══════════════════════════════════════════════════════════════
#  SafeGuard AI — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# Comma-separated list of allowed CORS origins (JSON format)
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# ── MongoDB ────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=safeguard_ai

# ── Cloudinary ─────────────────────────────────────────────────
# Get these from https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Redis / Celery ─────────────────────────────────────────────
# Local:   redis://localhost:6379/0
# Upstash: rediss://:password@host:port
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── HuggingFace ────────────────────────────────────────────────
# Model options for multilingual support:
#   - citizenlab/distilbert-base-multilingual-cased-toxicity (recommended)
#     Supports: 100+ languages including English, Hindi, Bengali, Urdu
#   - Hate-speech-CNERG/dehatebert-mono-hindi
#     Supports: Hindi only (best accuracy for Hindi)
#   - unitary/toxic-bert
#     Supports: English only
HF_MODEL_NAME=citizenlab/distilbert-base-multilingual-cased-toxicity
HF_CACHE_DIR=/tmp/hf_cache
# Set to "cuda" if a GPU is available
HF_DEVICE=cpu

# ── File storage ───────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
FIR_OUTPUT_DIR=/tmp/fir_pdfs

# ── Frontend (Next.js) ─────────────────────────────────────────
# Must be prefixed NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
